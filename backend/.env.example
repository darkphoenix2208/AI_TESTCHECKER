# Flask Environment
FLASK_ENV=production

# Server Configuration
PORT=5000
HOST=0.0.0.0

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/secure_exam_db
DB_NAME=secure_exam_db

# MongoDB Connection Settings (milliseconds)
MONGO_SERVER_SELECTION_TIMEOUT=15000
MONGO_CONNECT_TIMEOUT=15000
MONGO_SOCKET_TIMEOUT=15000
MONGO_MAX_POOL_SIZE=10

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000

# YOLO Model Configuration
YOLO_MODEL_PATH=yolov5n.pt
YOLO_CONFIDENCE=0.4
YOLO_IOU=0.45
YOLO_MAX_DETECTIONS=10

# Face Recognition Configuration
FACE_CONFIDENCE_THRESHOLD=60

# Teacher Session Configuration (hours)
TEACHER_SESSION_TTL_HOURS=4

# Audio Detection Configuration
AUDIO_QUEUE_MAX_SIZE=200
